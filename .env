NODE_ENV=development
PORT=3000

DB_TYPE=sqlite
DB_PATH=data/time-off.sqlite
DB_SYNCHRONIZE=false
DB_LOGGING=false

HCM_INTEGRATION_MODE=mock
HCM_BASE_URL=http://localhost:4000
HCM_API_TIMEOUT_MS=5000
HCM_API_MAX_RETRIES=3
HCM_MOCK_RANDOM_FAILURE_RATE=0.15
HCM_MOCK_DELAY_MS=250
HCM_SYNC_SERVICE_TOKEN=change-me-sync-token
HCM_SYNC_SIGNATURE_TTL_SECONDS=300
